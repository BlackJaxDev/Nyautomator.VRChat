    {
      "key": "variableName",
      "name": "Global Variable Name",
      "value": "camera_trigger_automation",
      "type": "string"
    }
  ],
  "steps": [
    "obs-scene",
    "vrchat-parameter",
    "toggle-global-variable",
    "log"
