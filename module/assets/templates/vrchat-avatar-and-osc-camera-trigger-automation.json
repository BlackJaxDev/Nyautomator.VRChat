{
  "$schema": "nyautomator.template.v1",
  "id": "vrchat-avatar-and-osc-camera-trigger-automation",
  "kind": "automation-workflow",
  "title": "Camera trigger automation",
  "group": "VRChat Avatar And OSC",
  "summary": "VRChat.OSC.Camera.* change -> branch -> switch OBS scene or toggle source for photo mode.",
  "description": "Camera trigger automation: VRChat.OSC.Camera.* change -> branch -> switch OBS scene or toggle source for photo mode.",
